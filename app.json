{
  "expo": {
    "name": "Xplorers",
    "slug": "xplorers",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "xplorers",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#14532d"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.xplorers.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Xplorers usa tu ubicación para mostrarte campings cercanos y verificar check-ins.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Xplorers usa tu ubicación para mostrarte campings cercanos."
      }
    },
    "android": {
      "package": "com.xplorers.app",
      "adaptiveIcon": {
        "backgroundColor": "#14532d",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Xplorers usa tu ubicación para mostrarte campings cercanos y verificar check-ins."
        }
      ],
      "@rnmapbox/maps"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
